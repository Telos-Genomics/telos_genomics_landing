---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.svelte";
import WhoIsItFor from "../components/WhoIsItFor.svelte";
import HowItWorks from "../components/HowItWorks.svelte";
import WhyNow from "../components/WhyNow.svelte";
import ContactUs from "../components/ContactUs.svelte";

const canonicalUrl = "https://telosgenomics.bio";
const excerpt = "";
---

<Layout title="Telos Genomics" canonicalUrl={canonicalUrl} excerpt={excerpt}>
	<Hero client:load />
	<WhoIsItFor client:load />
	<HowItWorks client:load />
	<WhyNow client:only />
	<ContactUs client:load />
</Layout>
